# Raw memory dumps are too large for git (253MB+)
# Keep locally, don't push
dumps/memory_dump_*.json

# Python cache
__pycache__/
*.pyc

# Temp files
_pgdump.bat
_check_pydivert.py

# Traffic captures — keep summaries, exclude raw data
traffic/*.pcap
traffic/*.jsonl
traffic/raw_streams/
traffic/sniff_stdout.log
traffic/mitmdump_*.log
